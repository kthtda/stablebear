{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 19, "patch": 0 },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (minimal module build)",
      "description": "Plain CMake build of _mpcf_cpu (+_mpcf_cudaXX if CUDA), symlinked into masspcf/",
      "binaryDir": "${sourceDir}/cmake-build-debug",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": "debug",
      "displayName": "Release (benchmarks/perf)",
      "description": "Optimized build. Always use for benchmarks/perf tests.",
      "binaryDir": "${sourceDir}/cmake-build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug-nocuda",
      "inherits": "debug",
      "displayName": "Debug, CUDA off",
      "environment": { "BUILD_WITH_CUDA": "0" }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" },
    { "name": "debug-nocuda", "configurePreset": "debug-nocuda" },
    { "name": "tests", "configurePreset": "debug", "targets": ["mpcf_test"] }
  ]
}
